{
  "expo": {
    "name": "Mixtape FM",
    "slug": "MiRadio",
    "version": "1.0.1", // 🔥 Actualiza versión
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mixtapeoficialmx.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.mixtapeoficialmx.app",
      "versionCode": 4, // 🔥 Incrementa esto para nueva build
      "permissions": [
        "INTERNET",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ced480e7-ea6f-4efe-993a-798a91b9a143"
      }
    }
  }
}